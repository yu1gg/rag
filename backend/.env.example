# =========================
# 应用基础配置
# 这些值控制后端服务名、监听地址和前端跨域联调范围。
# =========================
APP_NAME=RAG 智能问答与文本摘要系统 API
APP_VERSION=2.0.0
APP_HOST=127.0.0.1
APP_PORT=8050
ALLOWED_ORIGINS=*

# =========================
# LLM 配置
# OPENAI_BASE_URL / OPENAI_MODEL 可替换成任意 OpenAI 兼容服务。
# QA_MAX_TOKENS 单独收紧，是为了让问答默认更偏速度优先。
# =========================
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_TIMEOUT=20
OPENAI_RETRIES=1
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048
QA_MAX_TOKENS=512

# =========================
# 向量检索模型配置
# MODEL_LOCAL_ONLY=true 表示本地没有模型时快速降级，不等待远程下载探测。
# PREWARM_RAG_ON_STARTUP=true 会让启动稍慢一点，但通常能显著改善首问速度。
# =========================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=32
MODEL_LOCAL_ONLY=true
PREWARM_RAG_ON_STARTUP=true

# =========================
# 检索性能配置
# RERANK_ENABLED 默认关闭，优先保证接口响应速度。
# QA_CONTEXT_* 只限制送给 LLM 的上下文大小，不影响最终返回给前端的 references。
# =========================
RETRIEVAL_TOP_K=5
RERANK_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
QA_CONTEXT_TOP_K=3
QA_CONTEXT_MAX_CHARS=1600

# =========================
# 数据准备与评估脚本配置
# 这部分主要给 collect / clean / chunk / eval 脚本使用。
# =========================
ARXIV_MAX_RESULTS=50
ARXIV_QUERY=deep learning natural language processing machine learning transformer BERT GPT
NEWS_MAX_ARTICLES=30
QA_MIN_PAIRS=200
CHUNK_SIZE=512
CHUNK_OVERLAP=128
MIN_CHUNK_LENGTH=20

# =========================
# 运行期存储目录
# 相对路径默认会解析到 backend/ 目录下。
# =========================
STORAGE_DIR=storage
